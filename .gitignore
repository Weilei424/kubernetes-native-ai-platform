pip-wheel-metadata/
*.whl
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# ============================================================
# Secrets and credentials — never commit these
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
vault-token
vault-root-token
*.credentials
secrets/
**/secrets/
kubeconfig
*.kubeconfig

# ============================================================
# Terraform (infra/terraform)
# ============================================================
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log
crash.*.log

# ============================================================
# Helm (infra/helm)
# ============================================================
charts/*.tgz
/infra/helm/**/charts/
/infra/helm/**/Chart.lock

# ============================================================
# Kubernetes manifests — generated/rendered only
# ============================================================
/infra/kubernetes/rendered/

# ============================================================
# MLflow (local artifact store, tracking)
# ============================================================
mlruns/
mlartifacts/
mlflow.db

