# ============================================================
# Go (control-plane, cli, operator)
# ============================================================
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
/control-plane/bin/
/cli/bin/
/operator/bin/
vendor/
/control-plane/server

# ============================================================
# Python (sdk/python, training-runtime, examples)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
.venv/
venv/
env/
dist/
build/
*.egg-info/
